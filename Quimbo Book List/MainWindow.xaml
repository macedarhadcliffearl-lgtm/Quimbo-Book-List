<Window x:Class="Quimbo_Book_List.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Book Collection"
        Height="500" Width="950"
        Background="#F4F4F4"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- BUTTON STYLE -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#EADBC8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D6C3A3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TEXTBOX STYLE -->
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Gray"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="BOOK COLLECTION"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10"/>

        <!-- LEFT SIDE -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="10">

            <DataGrid x:Name="dataGrid"
                      Height="320"
                      AutoGenerateColumns="False"
                      AlternatingRowBackground="#EFEFEF"
                      RowHeight="30"
                      CanUserAddRows="False"
                      SelectionChanged="dataGrid_SelectionChanged">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Brand" Binding="{Binding Brand}" Width="*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=₱{0:F2}}" Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button x:Name="btnDeleteData"
                    Content="DELETE SELECTED"
                    Height="45"
                    IsEnabled="False"
                    Click="btnDeleteData_Click"/>
        </StackPanel>

        <!-- RIGHT SIDE (FORM CARD) -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="10">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FORM TITLE -->
                <TextBlock Text="Book Details"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- NAME -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Name"/>
                    <TextBox x:Name="txtName"/>
                </StackPanel>

                <!-- BRAND -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Brand"/>
                    <TextBox x:Name="txtBrand"/>
                </StackPanel>

                <!-- PRICE -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Price"/>
                    <TextBox x:Name="txtPrice"/>
                </StackPanel>

                <!-- CATEGORY -->
                <StackPanel Grid.Row="4" Margin="0,10,0,0">
                    <TextBlock Text="Category"/>
                    <StackPanel Orientation="Vertical">
                        <RadioButton x:Name="rbA" Content="Finance" GroupName="Category"/>
                        <RadioButton x:Name="rbB" Content="Self-help" GroupName="Category"/>
                        <RadioButton x:Name="rbC" Content="Classic" GroupName="Category"/>
                        <RadioButton x:Name="rbD" Content="Science" GroupName="Category"/>
                    </StackPanel>
                </StackPanel>

                <!-- SAVE BUTTON -->
                <Button x:Name="btnSave"
                        Grid.Row="5"
                        Content="SAVE"
                        Height="45"
                        Margin="0,15,0,0"
                        Click="btnSave_Click"/>

            </Grid>
        </Border>

    </Grid>
</Window>